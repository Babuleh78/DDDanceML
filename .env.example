# Copy to .env and fill in real values. NEVER commit the real .env.

# --- S3 / object storage (Selcloud in prod, MinIO in dev) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme
S3_BUCKET=dddance
S3_REGION=us-east-1

# --- Redis (broker, result backend, cache) ---
REDIS_PASSWORD=changeme
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# --- Go backend callback ---
GO_BACKEND_URL=http://main:5458
ML_INTERNAL_TOKEN=changeme        # shared secret for Go -> ML internal calls
ADMIN_TOKEN=changeme              # protects admin-only endpoints

# --- Mixamo / skeleton retargeting ---
MIXAMO_MODEL_PATH=/app/models/mixamo_model.json
MIXAMO_MIN_VISIBILITY=0.6
MIXAMO_HIPS_MOVE=false
MIXAMO_MAX_FRAMES=5000

# --- Blender (GLB rendering) ---
BLENDER_EXECUTABLE=blender
BLENDER_CHARACTER_BLEND=character.blend

# --- Segmentation (quaternion-energy) ---
SEGMENTER_MIN_SEG_SEC=0.5
SEGMENTER_SENSITIVITY=0.4
SEGMENTER_SMOOTH_WINDOW=11

# --- Optional LLM segment labeling ---
LABELING_ENABLED=false
LABELING_CACHE_TTL=3600
LABELING_CACHE_SIZE=1000

# --- Moderation (YOLO + nudenet) ---
MODERATE_POWER=5
MODERATE_YOLO_MODEL=yolov8n.pt
MODERATE_MULTI_PERSON_CHECK=true
MODERATE_PERSON_MIN_REL_AREA=0.5

# --- Telegram bot (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Outbound proxies for yt-dlp / telegram (optional) ---
YTDLP_PROXY=
PROXY_INSTAGRAM=
PROXY_TIKTOK=
PROXY_VK=
TELEGRAM_PROXY=

# --- Misc ---
DEBUG_MODE=false
